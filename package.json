{
  "name": "angular-template",
  "version": "1.0.2",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "node ./build/build-pre.js && ng build --configuration=production --aot --base-href / --output-path dist/ --deploy-url /",
    "build-production": "node ./build/build-pre.js && ng build --configuration=production --aot --base-href / --output-path dist/ --deploy-url /",
    "build-uat": "node ./build/build-pre.js && ng build --configuration=uat --aot --base-href / --output-path dist/ --deploy-url /",
    "debug": "ng build --base-href /",
    "server": "node server.js",
    "e2e": "playwright test",
    "e2e:auth": "playwright test --project=setup",
    "e2e:save-token": "node e2e/save-token.mjs",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "private": true,
  "main": "main.js",
  "dependencies": {
    "@angular/animations": "20.3.18",
    "@angular/common": "20.3.18",
    "@angular/compiler": "20.3.18",
    "@angular/core": "20.3.18",
    "@angular/forms": "20.3.18",
    "@angular/localize": "^20.3.18",
    "@angular/platform-browser": "20.3.18",
    "@angular/platform-browser-dynamic": "20.3.18",
    "@angular/router": "20.3.18",
    "@apollo/client": "^4.1.7",
    "@auth0/angular-jwt": "^5.2.0",
    "@auth0/auth0-angular": "^2.8.0",
    "@fortawesome/fontawesome-free": "^5.14.0",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@ng-bootstrap/ng-bootstrap": "^19.0.1",
    "@ng-select/ng-select": "^20.7.0",
    "@ngx-formly/bootstrap": "^7.1.0",
    "@ngx-formly/core": "^7.1.0",
    "@ngxs/devtools-plugin": "^20.1.0",
    "@ngxs/form-plugin": "^20.1.0",
    "@ngxs/logger-plugin": "^20.1.0",
    "@ngxs/router-plugin": "^20.1.0",
    "@ngxs/store": "^20.1.0",
    "@popperjs/core": "^2.11.8",
    "apollo-angular": "^13.0.0",
    "bootstrap": "^5.3.8",
    "core-js": "^3.49.0",
    "datatables.net": "^2.3.7",
    "datatables.net-bs5": "^2.3.7",
